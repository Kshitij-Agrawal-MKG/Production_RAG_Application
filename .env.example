# ── Required ──────────────────────────────────────────────────────────
# Get a free Gemini API key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# ── Optional: Langfuse distributed tracing ────────────────────────────
# Sign up free at https://cloud.langfuse.com, create a project,
# then copy your keys from Settings → API Keys.
# If these are not set, all tracing calls are silent no-ops — the
# pipeline runs normally without Langfuse.
LANGFUSE_PUBLIC_KEY=your_key_here
LANGFUSE_SECRET_KEY=your_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# For self-hosted Langfuse, replace LANGFUSE_HOST with your server URL:
# LANGFUSE_HOST=http://localhost:3000
